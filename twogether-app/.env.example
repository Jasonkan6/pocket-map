# Copy to .env and fill in. All keys are bundled into the client (EXPO_PUBLIC_*).
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Same value as GEMINI_API_KEY in the backend .env (used for screenshot place extraction).
EXPO_PUBLIC_GEMINI_API_KEY=your-gemini-api-key
